{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./",
    "module": "node16", //commonjs
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": false, 
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node", "vscode"]
  },
  "include": ["./*.ts"],
  "exclude": ["node_modules", ".vscode"]
}